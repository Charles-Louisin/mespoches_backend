# MongoDB
MONGODB_URI=

# Auth (jamais côté frontend)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Serveur
PORT=5000
NODE_ENV=development

# Frontend (CORS + return_url CinetPay)
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# URL publique de cette API (webhook CinetPay — ngrok en dev si besoin)
API_PUBLIC_URL=http://localhost:5000

# CinetPay — https://cinetpay.com
CINETPAY_API_KEY=
CINETPAY_SITE_ID=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MES POCHES <onboarding@resend.dev>
RESEND_REPLY_TO=

# Dépenses prévues (cron UTC — optionnel)
# PLANNED_EXPENSE_REMINDER_HOUR_UTC=8
# PLANNED_EXPENSE_EXECUTE_HOUR_UTC=0
# PLANNED_EXPENSE_EXECUTE_MINUTE_UTC=5

# UploadThing (optionnel)
UPLOADTHING_TOKEN=
