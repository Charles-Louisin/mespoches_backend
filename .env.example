# MongoDB
MONGODB_URI=

# Auth (jamais côté frontend)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Serveur
PORT=5000
NODE_ENV=production

# Frontend (CORS + pages retour CinetPay — HTTPS obligatoire en prod)
CORS_ORIGIN=https://votre-domaine.com
APP_URL=https://votre-domaine.com

# URL publique HTTPS de cette API (webhook : …/api/webhooks/cinetpay)
API_PUBLIC_URL=https://api.votre-domaine.com

# CinetPay v1 — compte marchand Cameroun (XAF)
# production → api.cinetpay.co | sandbox → api.cinetpay.net
# Liste blanche IP : IP SORTANTE du serveur qui héberge ce backend (voir /api/subscription/cinetpay-setup)
CINETPAY_ENV=production
CINETPAY_ACCOUNT_KEY=
CINETPAY_ACCOUNT_PASSWORD=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MES POCHES <onboarding@resend.dev>
RESEND_REPLY_TO=

# Dépenses prévues (cron UTC — optionnel)
# PLANNED_EXPENSE_REMINDER_HOUR_UTC=8
# PLANNED_EXPENSE_EXECUTE_HOUR_UTC=0
# PLANNED_EXPENSE_EXECUTE_MINUTE_UTC=5

# UploadThing (optionnel)
UPLOADTHING_TOKEN=
