# MongoDB
MONGODB_URI=

# Auth (jamais côté frontend)
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Serveur
PORT=5000
NODE_ENV=development

# Frontend (CORS + return_url CinetPay)
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000

# URL publique de cette API (webhook CinetPay — ngrok / cloudflared en sandbox)
# Ex. https://xxxx.ngrok-free.app
API_PUBLIC_URL=http://localhost:5000

# CinetPay v1 — https://cinetpay.com (espace marchand → Développeur)
# Sandbox : CINETPAY_ENV=sandbox  → api.cinetpay.net
# Production : CINETPAY_ENV=production → api.cinetpay.co
CINETPAY_ENV=sandbox
CINETPAY_ACCOUNT_KEY=
CINETPAY_ACCOUNT_PASSWORD=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=MES POCHES <onboarding@resend.dev>
RESEND_REPLY_TO=

# Dépenses prévues (cron UTC — optionnel)
# PLANNED_EXPENSE_REMINDER_HOUR_UTC=8
# PLANNED_EXPENSE_EXECUTE_HOUR_UTC=0
# PLANNED_EXPENSE_EXECUTE_MINUTE_UTC=5

# UploadThing (optionnel)
UPLOADTHING_TOKEN=
